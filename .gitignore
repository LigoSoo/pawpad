# PawPad Agentic Engineering Toolkit
.claude/pawpad/backup/
.claude/settings.local.json
.ctxdb/.state/

# ─────────────────────────────────────────────────────────────────────────────
# PawPad runtime / working memory — NEVER distribute personal dogfooded data.
# These are regenerated fresh by `pawpad-setup.ps1` on install/upgrade.
# Static skeleton (README/TEMPLATE/VERSION) is kept so the dir tree survives clone.
# ─────────────────────────────────────────────────────────────────────────────

# pawpad lane/state/history (working memory)
.claude/pawpad/_wip.md
.claude/pawpad/_meta.md
.claude/pawpad/sessions/
.claude/pawpad/decisions/
.claude/pawpad/verifications/
.claude/pawpad/reviews/

# wip lanes — keep README + done/README only
.claude/pawpad/wip/*
!.claude/pawpad/wip/README.md
!.claude/pawpad/wip/done/
.claude/pawpad/wip/done/*
!.claude/pawpad/wip/done/README.md

# handoff snapshots — keep README + TEMPLATE only
.claude/pawpad/handoffs/*
!.claude/pawpad/handoffs/README.md
!.claude/pawpad/handoffs/TEMPLATE.md

# PRD specs — keep README + TEMPLATE only
.claude/pawpad/specs/*
!.claude/pawpad/specs/README.md
!.claude/pawpad/specs/TEMPLATE.md

# codebase-map 7-axis digest — keep README only
.claude/pawpad/codebase/*
!.claude/pawpad/codebase/README.md

# ctxdb keyword DB — router + L1/L2/L3 narratives (regenerated by setup)
.ctxdb/INDEX.md
.ctxdb/L1/
.ctxdb/L2/
.ctxdb/L3/

# codemap symbol registry (reveals codebase; regenerated by setup)
.claude/codemap/_index.md

# project glossary (may hold domain memory)
CONTEXT.md
